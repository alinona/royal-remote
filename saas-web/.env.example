# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/eduflow"

# ─── Authentication ────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-a-strong-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── AI (Anthropic) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# ─── Redis (Optional) ─────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── File Storage ─────────────────────────────────────────────────────────────
S3_BUCKET="eduflow-files"
S3_REGION="me-south-1"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_ENDPOINT="https://s3.me-south-1.amazonaws.com"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="EduFlow"
NODE_ENV="development"

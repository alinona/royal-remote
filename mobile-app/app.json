{
  "expo": {
    "name": "EduFlow Teacher",
    "slug": "eduflow-teacher",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F63D2"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "sa.eduflow.teacher",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "لالتقاط صور الملفات والوثائق",
        "NSFaceIDUsageDescription": "للدخول السريع بالتعرف على الوجه",
        "NSLocalNetworkUsageDescription": "للمزامنة مع الخادم المحلي"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F63D2"
      },
      "package": "sa.eduflow.teacher",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        { "faceIDPermission": "تسجيل الدخول بالتعرف على الوجه" }
      ]
    ],
    "extra": {
      "API_BASE_URL": "https://api.eduflow.sa",
      "eas": { "projectId": "eduflow-teacher" }
    },
    "scheme": "eduflow"
  }
}
